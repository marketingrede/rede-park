# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

# Database
DB_CONNECTION=libsql

# Turso (libSQL) - required for production
LIBSQL_URL=libsql://your-database-name-your-org.turso.io
LIBSQL_AUTH_TOKEN=your-auth-token